<%- include("partials/header") %>
<link rel="stylesheet" href="/css/syllabus.css">

<div class="page-content">
<div class="title-row">
  <h1 class="title">Syllabus Status</h1>


  <select onchange="changeYear(this.value)" class="year-dropdown">
    <option value="2025-26">2025-26</option>
    <option value="2026-27">2026-27</option>
  </select>
</div>
<div class="divider"></div>

  <!-- ✅ YAHAN ADD KARNA HAI -->
  <div class="tabs">
    <button class="tab-btn" onclick="showTab('CGpsc')">
      CGPSC - <span><%= CGpscProgress || 90 %>%</span>
    </button>

    <button class="tab-btn" onclick="showTab('vyapam')">
      VYAPAM - <span><%= vyapamProgress || 80 %>%</span>
    </button>
  </div>
  
  <!-- 👇 IMPORTANT: table div ke andar -->
<div id="CGpscTable" class="table-box">
  <table class="syllabus-table">
    <thead>
      <tr>
        <th>S.N</th>
        <th>Subject</th>
        <th>Faculty</th>
        <th>Start Date</th>
        <th>End Date</th>
        <th>Planned</th>
        <th>Executed</th>
        <th>Status</th>
      </tr>
    </thead>

  
    <tbody>
  <% if (CGpscData && CGpscData.length > 0) { %>
    <% CGpscData.forEach(row => { %>
      <tr>
        <td><%= row.sn %></td>
        <td><%= row.subject %></td>
        <td><%= row.faculty %></td>
        <td><%= row.startDate %></td>
        <td><%= row.endDate %></td>
        <td><%= row.planned %></td>
        <td><%= row.executed %></td>
        <td class="<%= row.status.toLowerCase() %>"><%= row.status %></td>
      </tr>
    <% }) %>
  <% } else { %>
    <tr>
      <td colspan="8">No data found</td>
    </tr>
  <% } %>
</tbody>
  </table>
</div>

<div id="vyapamTable" class="table-box" style="display:none;">
  <table class="syllabus-table">
    <thead>
      <tr>
        <th>S.N</th>
        <th>Subject</th>
        <th>Faculty</th>
        <th>Start Date</th>
        <th>End Date</th>
        <th>Planned</th>
        <th>Executed</th>
        <th>Status</th>
      </tr>
    </thead>

    <tbody>
      <% if (vyapamData && vyapamData.length > 0) { %>
        <% vyapamData.forEach(row => { %>
          <tr>
            <td><%= row.sn %></td>
            <td><%= row.subject %></td>
            <td><%= row.faculty %></td>
            <td><%= row.startDate %></td>
            <td><%= row.endDate %></td>
            <td><%= row.planned %></td>
            <td><%= row.executed %></td>
            <td class="<%= row.status.toLowerCase() %>"><%= row.status %></td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="8">No data found</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<!-- table ke baad -->
<script>
function showTab(tab) {
  const cg = document.getElementById("CGpscTable");
  const vy = document.getElementById("vyapamTable");

  if (tab === "CGpsc") {
    cg.style.display = "block";
    vy.style.display = "none";
  } else {
    cg.style.display = "none";
    vy.style.display = "block";
  }

  document.querySelectorAll(".tab-btn").forEach(btn => {
    btn.classList.remove("active");
  });

  if (tab === "CGpsc") {
    document.querySelectorAll(".tab-btn")[0].classList.add("active");
  } else {
    document.querySelectorAll(".tab-btn")[1].classList.add("active");
  }
}
function changeYear(year){
  window.location.href = "/admin/syllabus?year=" + year;
}
</script>


<%- include("partials/footer") %>