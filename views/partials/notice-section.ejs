<link rel="stylesheet" href="/css/notice.css">

<section class="updates-section">

  <!-- Green Title -->
  <div class="section-title-pill">
    📢 Latest Updates & Events
  </div>

  <%
  const latestNotices = notices?.filter(n => n.type === "Notice") || [];
  const events = notices?.filter(n => n.type === "Event") || [];
  %>

  <div class="notice-grid">

    <!-- LEFT -->
    <div class="updates-card">

      <h3>Latest Updates</h3>

      <div class="notice-marquee">

        <% if(latestNotices.length > 0){ %>

          <% latestNotices.forEach(n => { %>

            <div class="notice-item">
              <a href="<%= n.link %>" target="_blank">
                <%= n.title %>
              </a>
            </div>

          <% }) %>

        <% } else { %>

          <div class="notice-item">
            No updates available.
          </div>

        <% } %>

      </div>

    </div>

    <!-- RIGHT -->
    <div class="updates-card">

      <h3>Our Events</h3>

      <div class="notice-marquee">

        <% if(events.length > 0){ %>

          <% events.forEach(n => { %>

            <div class="notice-item">
              <a href="<%= n.link %>" target="_blank">
                <%= n.title %>
              </a>
            </div>

          <% }) %>

        <% } else { %>

          <div class="notice-item">
            No events available.
          </div>

        <% } %>

      </div>

    </div>

  </div>

</section>