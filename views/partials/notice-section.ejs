<link rel="stylesheet" href="/css/notice.css">

<section class="updates-section">

  <!-- Green Title -->
  <div class="section-line-header">

  <div class="section-badge">
    📢 Latest Updates & Events
  </div>

</div>
  <%
  const latestNotices = notices?.filter(n => n.type === "Notice") || [];
  const events = notices?.filter(n => n.type === "Event") || [];
  %>

  <div class="notice-grid">

    <!-- LEFT -->
    <div class="updates-card">

      <h3>📢 Latest Updates</h3>
<div class="notice-marquee">

  <% if(latestNotices.length > 0){ %>

    <% latestNotices.forEach(n => { %>

      <div class="notice-item">

   <div class="notice-title-row">

  <% if(n.link){ %>

    <a href="<%= n.link %>" target="_blank">
      <strong>📌 <%= n.title %></strong>
    </a>

  <% } else { %>

    <strong>📌 <%= n.title %></strong>

  <% } %>

  <span class="notice-date">
    • <%= new Date(n.createdAt).toLocaleDateString('en-GB',{
        day:'numeric',
        month:'short',
        year:'numeric'
    }) %>
  </span>

</div>

<% if(n.description){ %>

  <p class="notice-desc">
    <%= n.description %>
  </p>

<% } %>

      </div>

    <% }) %>

  <% } else { %>

    <div class="notice-item">
      No updates available.
    </div>

  <% } %>

</div>

    </div>

    <!-- RIGHT -->
    <div class="updates-card">

      <h3>🎯 Important Events</h3>
<div class="notice-marquee">

  <% if(events.length > 0){ %>

    <% events.forEach(n => { %>

      <div class="notice-item">

    <div class="notice-title-row">

  <% if(n.link){ %>

    <a href="<%= n.link %>" target="_blank">
      <strong>🔹 <%= n.title %></strong>
    </a>

  <% } else { %>

    <strong>🔹 <%= n.title %></strong>

  <% } %>

  <span class="notice-date">
    • <%= new Date(n.createdAt).toLocaleDateString('en-GB',{
        day:'numeric',
        month:'short',
        year:'numeric'
    }) %>
  </span>

</div>

<% if(n.description){ %>

  <p class="notice-desc">
    <%= n.description %>
  </p>

<% } %>

      </div>

    <% }) %>

  <% } else { %>

    <div class="notice-item">
      No events available.
    </div>

  <% } %>

</div>

    </div>

  </div>

</section>