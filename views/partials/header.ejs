<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BCCP – Program Overview</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/common.css">
</head>
<body>

<!-- FLOATING MENU -->
<div class="floating-menu">
  <button class="menu-btn" onclick="toggleMenu()">☰ Menu</button>
  <div class="menu-dropdown">
    <a href="/">Home</a>
    <a href="/student">Student Profiles</a>
    <a href="/staff">Staff Details</a>
    <a href="/admin/syllabus">Syllabus Status</a>
    <a href="/achievement/manage">Achievements</a>
    <a href="/feedback">Feedback</a>
    <a href="/testimonials">Testimonials</a>

     <hr style="margin:6px 0">

     <% if (user) { %>

    <% if (user.role === 'admin') { %>
        <a href="/admin/dashboard">Admin Panel</a>
    <% } %>

    <% if (user.role === 'student') { %>
        <a href="/student">My Profile</a>
    <% } %>

    <a href="/logout" class="logout">Logout</a>

<% } else { %>

    <a href="/login">Login</a>

<% } %>


  </div>
</div>

<!-- TOP BAR -->
<div class="top-bar">

  <!-- LEFT: Implementing Partners -->
  <div class="left">
    <img src="/logos/logo_vidyabhawan.png" alt="Vidya Bhawan Society">
  
  </div>

 <div class="center">
  <div class="program-name">
    <span class="program-full">BALCO Connect Coaching Program</span>
  </div>
</div>

  <!-- RIGHT: CSR PARTNER -->
  <div class="right">
    <img src="/logos/logo_vedanta.png" alt="Vedanta">
  </div>

</div>   <!-- THIS closes top-bar -->
<!-- Menu Toggle Script -->
<script>
function toggleMenu(){
  const menu = document.querySelector(".menu-dropdown");

  if(menu.style.display === "block"){
    menu.style.display = "none";
  } else {
    menu.style.display = "block";
  }
}

document.addEventListener("click", function(e){
  const menu = document.querySelector(".menu-dropdown");
  const button = document.querySelector(".menu-btn");

  if(!button.contains(e.target) && !menu.contains(e.target)){
    menu.style.display="none";
  }
});
</script>