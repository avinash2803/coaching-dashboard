<!DOCTYPE html>
<html>
<head>
    <title>BCCP AI Assistant</title>

    <style>

        body {
            font-family: Arial, sans-serif;
            background: #f4f4f4;
            margin: 0;
        }

        .chat-container {
    width: 360px;
    height: 540px;
    position: fixed;
    bottom: 110px;
    right: 20px;
    background: white;
    border-radius: 15px;
    box-shadow: 0 0 20px rgba(0,0,0,0.2);
    overflow: hidden;
    display: none;
    flex-direction: column;
    z-index: 9999;
}

        .chat-header {
    background: #b71c1c;
    color: white;
    padding: 8px;
    font-size: 14px;
    font-weight: bold;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

        .chat-body {
            flex: 1;
            overflow-y: auto;
            padding: 15px;
            background: #fafafa;
        }

        .welcome-box {
            text-align: center;
            margin-bottom: 15px;
        }

        .welcome-box h3 {
            color: #b71c1c;
            margin-bottom: 5px;
        }

        .quick-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            justify-content: center;
            margin-top: 15px;
        }

        .quick-actions button{

    width:145px;
    height:46px;

    border:none;
    background:#f3f3f3;

    border-radius:25px;

    font-size:16px;
    font-weight:500;

    cursor:pointer;

    transition:.25s;
}

.quick-actions button:hover{

    background:#b71c1c;
    color:white;
    transform:translateY(-2px);

}

        .bot-message {
            background: #f1f1f1;
            padding: 10px;
            border-radius: 10px;
            margin-bottom: 10px;
        }

        .user-message {
            background: #b71c1c;
            color: white;
            padding: 10px;
            border-radius: 10px;
            margin-bottom: 10px;
            text-align: right;
        }

        .chat-footer {
            display: flex;
            border-top: 1px solid #ddd;
        }

        .chat-footer input {
            flex: 1;
            padding: 12px;
            border: none;
            outline: none;
        }

        .chat-footer button {
            width: 80px;
            border: none;
            background: #b71c1c;
            color: white;
            cursor: pointer;
        }

        #chat-launcher {
    position: fixed;
    bottom: 20px;
    right: 20px;
    width: 75px;
    height: 75px;
    border-radius: 50%;
    background: #b71c1c;
    color: white;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    box-shadow: 0 5px 15px rgba(0,0,0,0.3);
    z-index: 10000;
    text-align: center;
}

.launcher-icon {
    font-size: 22px;
    line-height: 1;
}

.bccp {
    font-size: 16px;
    font-weight: bold;
    line-height: 1.1;
}

.ai {
    font-size: 12px;
    letter-spacing: 2px;
}

.close-btn {
    cursor: pointer;
    font-size: 20px;
}

.header-icons{
    display:flex;
    align-items:center;
    gap:15px;
}

.header-icons span{
    cursor:pointer;
    font-size:18px;
    transition:.25s;
}

#resetChat:hover{
    transform:rotate(180deg);
    color:#ffe082;
}

#closeChat:hover{
    color:#ffe082;
}

    </style>
</head>

<body>
<div id="chat-launcher">

    <div class="launcher-icon">
        🤖
    </div>

    <div class="launcher-text">
        <div class="bccp">BCCP</div>
        <div class="ai">— AI —</div>
    </div>

</div>
<div class="chat-container">

    <div class="chat-header">
    <span>🤖 BCCP AI Assistant</span>

    <div class="header-icons">
        <span id="resetChat" title="New Chat">🔄</span>
        <span class="close-btn" id="closeChat">✖</span>
    </div>
</div>

    <div class="chat-body" id="chatBody">

        <div class="welcome-box" id="welcomeBox">

            <h3>Welcome to BALCO Connect</h3>

            <p>Bhoramdev Vidyapeeth Coaching Program</p>

            <div class="quick-actions">

                <button onclick="sendQuick('Enrollment')">
                    👨‍🎓 Enrollment
                </button>

                <button onclick="sendQuick('Attendance')">
                    📊 Attendance
                </button>

                <button onclick="sendQuick('Syllabus status')">
                    📚 Syllabus
                </button>

                <button onclick="sendQuick('Achievements')">
                    🏆 Achievements
                </button>

                <button onclick="sendQuick('Employment')">
                    💼 Employment
                </button>

                <button onclick="sendQuick('Faculty')">
                    👨‍🏫 Faculty
                </button>

            </div>

        </div>

    </div>

    <div class="chat-footer">

        <input
            type="text"
            id="message"
            placeholder="Type your message..."
            onkeypress="if(event.key==='Enter') sendMessage()"
        >

        <button onclick="sendMessage()">
            Send
        </button>

    </div>

</div>

<script>

let defaultWelcome;

window.onload = function () {
    defaultWelcome = document.getElementById("chatBody").innerHTML;
};

function addMessage(message, type) {

    const chatBody =
        document.getElementById("chatBody");

    const div =
        document.createElement("div");

    div.className =
        type === "user"
        ? "user-message"
        : "bot-message";

    if (type === "user") {
    div.textContent = message;
} else {
    div.innerHTML = message;
}

    chatBody.appendChild(div);

    chatBody.scrollTop =
        chatBody.scrollHeight;
}

function sendQuick(question) {

    document.getElementById(
        "welcomeBox"
    ).style.display = "none";

    sendMessage(question);
}

async function sendMessage(text = null) {

    const input =
        document.getElementById("message");

    const message =
        text || input.value.trim();

    if (!message) return;

    document.getElementById(
        "welcomeBox"
    ).style.display = "none";

    addMessage(message, "user");

    input.value = "";

    try {

    const response = await fetch("/api/chat", {

        method: "POST",

        headers: {
            "Content-Type": "application/json"
        },

        body: JSON.stringify({
            message
        })

    });

    const data = await response.json();

    let reply = data.reply;

    if (
        message.toLowerCase().includes("enrollment") ||
        message.toLowerCase().includes("student")
    ) {

        reply +=
        "<br><br>" +
        "<button onclick=\"sendQuick('Active students')\">📈 Active</button> " +
        "<button onclick=\"sendQuick('Dropout')\">📉 Dropout</button> " +
        "<button onclick=\"sendQuick('Selection rate')\">🏆 Selection</button>";
    }

    addMessage(reply, "bot");

} catch (err) {

    console.error(err);

    addMessage(
        "⚠ Unable to connect to AI Assistant.",
        "bot"
    );

}


}
document
.getElementById("chat-launcher")
.onclick = function () {

    document
    .querySelector(".chat-container")
    .style.display = "flex";

    document
    .getElementById("message")
    .focus();
};

document
.getElementById("closeChat")
.onclick = function () {

    document
    .querySelector(".chat-container")
    .style.display = "none";
};

document.getElementById("resetChat").onclick = function () {

    document.getElementById("chatBody").innerHTML = defaultWelcome;

    document.getElementById("message").value = "";


    document.getElementById("message").focus();

};
</script>

</body>
</html>