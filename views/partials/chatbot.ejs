<div id="chat-launcher">

    <div class="launcher-circle">
        🤖
    </div>

</div>


<div class="chat-container" id="chatContainer">

    <!-- ================= HEADER ================= -->

    <div class="chat-header">

        <div class="chat-header-left">

            <div class="bot-avatar">
                🤖
            </div>

            <div>

                <div class="assistant-title">
                    BALCO Connect AI
                </div>

                <div class="assistant-subtitle">
                    Bhoramdev Vidyapeeth Coaching
                </div>

            </div>

        </div>

        <div class="header-icons">

            <span
                id="resetChat"
                title="New Chat">
                🔄
            </span>

            <span
                id="closeChat"
                title="Close">
                ✖
            </span>

        </div>

    </div>

    <!-- ================= CHAT BODY ================= -->

    <div
        class="chat-body"
        id="chatBody">

        <!-- Welcome Screen -->

        <div
            class="welcome-box"
            id="welcomeBox">

            <div class="welcome-logo">

                🤖

            </div>

            <h2>

                Welcome to

                <br>

                BALCO Connect

            </h2>

            <p>

                Bhoramdev Vidyapeeth Coaching Program

            </p>

            <div class="welcome-card">

                I can help you with

            </div>

            <!-- Quick Buttons -->

            <div class="quick-actions">

                <button onclick="sendQuick('Enrollment')">

                    👨‍🎓 Enrollment

                </button>

                <button onclick="sendQuick('Attendance')">

                    📊 Attendance

                </button>

                <button onclick="sendQuick('Syllabus status')">

                    📚 Syllabus

                </button>

                <button onclick="sendQuick('Achievements')">

                    🏆 Achievements

                </button>

                <button onclick="sendQuick('Employment')">

                    💼 Employment

                </button>

                <button onclick="sendQuick('Faculty')">

                    👨‍🏫 Faculty

                </button>

                <button onclick="sendQuick('Latest Notice')">

                    📢 Notice

                </button>

                <button onclick="sendQuick('Library')">

                    📖 Library

                </button>

            </div>

        </div>

    </div>

    <!-- ================= FOOTER ================= -->

    <div class="chat-footer">

        <input

            id="message"

            type="text"

            placeholder="Ask me anything..."

            autocomplete="off"

            onkeypress="if(event.key==='Enter'){sendMessage()}"

        >

        <button

            id="sendBtn"

            onclick="sendMessage()">

            ➤

        </button>

    </div>

</div>

<script>
(function () {

    const launcher = document.getElementById("chat-launcher");
    const chatContainer = document.getElementById("chatContainer");
    const closeChat = document.getElementById("closeChat");

    console.log("Launcher:", launcher);
    console.log("Container:", chatContainer);

    if (launcher && chatContainer) {

        launcher.onclick = function () {
            chatContainer.style.display = "flex";
        };

    }

    if (closeChat && chatContainer) {

        closeChat.onclick = function () {
            chatContainer.style.display = "none";
        };

    }

})();
</script>