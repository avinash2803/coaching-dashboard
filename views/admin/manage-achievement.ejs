<h2>Manage Achievements</h2>

<div style="
  display:grid;
  grid-template-columns: repeat(3, 1fr);
  gap:20px;
">

  <% if (achievements && achievements.length > 0) { %>

    <% achievements.forEach(item => { %>

      <div style="
        border:1px solid #ddd;
        border-radius:12px;
        padding:15px;
        text-align:center;
        box-shadow:0 2px 8px rgba(0,0,0,0.1);
        background:#fff;
      ">

        <!-- 🖼️ IMAGE -->
  <img 
  src="/api/upload/<%= item.studentId?.photoId %>" 
  alt="student"
  style="
    width:120px;
    height:120px;
    border-radius:50%;
    object-fit:cover;
    margin-bottom:10px;
  "
>
        >

        <!-- 🧑 NAME -->
        <h3 style="margin:5px 0;">
          <%= item.studentId?.name %>
        </h3>

        <!-- 🎯 EXAM -->
        <span style="
          display:inline-block;
          padding:5px 10px;
          background:orange;
          color:white;
          border-radius:20px;
          font-size:14px;
        ">
          <%= item.examQualified %>
        </span>

      </div>

    <% }) %>

  <% } else { %>

    <p>No achievements found</p>

  <% } %>

</div>