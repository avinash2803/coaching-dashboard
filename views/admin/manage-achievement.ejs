<%- include("../partials/header") %>
<link rel="stylesheet" href="/css/achievement.css">
<div class="achievement-container">

  <!-- 🟦 LEFT SIDE -->
  <div class="overview-panel premium-panel">

  <!-- 👨‍🎓 STUDENTS -->
  <div class="section">
    <div class="section-title">👨‍🎓 Students</div>

    <div class="big-number">
      <%= stats?.students?.total || 0 %>
    </div>
    <div class="label">Total Students</div>

    <div class="split">
      <span>👦 <b><%= stats?.students?.boys || 0 %></b></span>
      <span>👧 <b><%= stats?.students?.girls || 0 %></b></span>
    </div>
  </div>

  <hr>

  <!-- 🎯 QUALIFIED -->
  <div class="section">
    <div class="section-title">🎯 Qualified</div>

    <div class="item">
      <div>🎓 CGPSC Pre</div>
      <div class="numbers">
        <span>👦 <%= stats?.qualified?.cgpsc?.boys || 0 %></span>
        <span>👧 <%= stats?.qualified?.cgpsc?.girls || 0 %></span>
      </div>
    </div>

    <div class="item">
      <div>📘 CG TET</div>
      <div class="numbers">
        <span>👦 <%= stats?.qualified?.ctet?.boys || 0 %></span>
        <span>👧 <%= stats?.qualified?.ctet?.girls || 0 %></span>
      </div>
    </div>

    <div class="item">
      <div>🧪 Lab Attendant</div>
      <div class="numbers">
        <span>👦 <%= stats?.qualified?.lab?.boys || 0 %></span>
        <span>👧 <%= stats?.qualified?.lab?.girls || 0 %></span>
      </div>
    </div>
  </div>

  <hr>

  <!-- 💼 EMPLOYMENT -->
  <div class="section">
    <div class="section-title">💼 Employment</div>

    <div class="big-number">
      <%= stats?.employment?.total || 0 %>
    </div>
    <div class="label">Total Employed</div>

    <div class="split">
      <span>👦 <b><%= stats?.employment?.boys || 0 %></b></span>
      <span>👧 <b><%= stats?.employment?.girls || 0 %></b></span>
    </div>
  </div>

</div>

  <!-- 🟩 RIGHT SIDE -->
  <div class="achievement-content">

    <div class="achievement-grid">

      <% if (achievements && achievements.length > 0) { %>

        <% achievements.forEach(item => { %>

          <!-- ✅ WRAPPER (VERY IMPORTANT) -->
 <div class="achievement-card-wrapper">

  <div class="certificate" id="certificate-<%= item._id %>">

    <h3 class="title">Congratulations</h3>

    <div class="photo-wrapper">
      <img src="/api/upload/<%= item.studentId?.photoId %>" class="profile" />
    </div>

    <p class="quote">
      From Classroom Walls <br> to Success Halls
    </p>

    <h2 class="name"><%= item.studentId?.name %></h2>

    <div class="exam">
      <%= item.examQualified %>
    </div>

    <p class="batch">
  <%= item.studentId?.course %> BATCH
</p>

  </div>  <!-- ✅ certificate close -->

</div>    <!-- ✅ wrapper close -->

        <% }) %>

      <% } else { %>

        <p>No achievements found</p>

      <% } %>

    </div>

  </div>

</div>

<%- include("../partials/footer") %>