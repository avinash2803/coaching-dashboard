<%- include("../partials/header") %>
<link rel="stylesheet" href="/css/achievement.css">
<div class="achievement-page">

<div class="achievement-hero">

  <div class="hero-content">

    <h1>🏆 Achievements</h1>

    <p class="hero-subtitle">
      Celebrating Student Success & Milestones
    </p>

    <p class="hero-description">
      Recognizing academic excellence, competitive examination
      achievements and employment success across all batches.
    </p>

  </div>

  <div class="hero-icon">
    🏆
  </div>

</div>

<div class="year-filter-bar">

<select onchange="window.location='?year='+this.value">

<option value="all" <%= (year === "all") ? "selected" : "" %>>
All Years
</option>

<option value="2025-26" <%= (year === "2025-26") ? "selected" : "" %>>
2025-26
</option>

<option value="2026-27" <%= (year === "2026-27") ? "selected" : "" %>>
2026-27
</option>

<option value="2027-28" <%= (year === "2027-28") ? "selected" : "" %>>
2027-28
</option>

<option value="2028-29" <%= (year === "2028-29") ? "selected" : "" %>>
2028-29
</option>

</select>

</div>

<%
let totalQualified = 0;
stats?.qualified?.forEach(q=>{
totalQualified += (q.boys||0)+(q.girls||0);
});

let totalEmployment = 0;
stats?.employment?.forEach(e=>{
totalEmployment += (e.boys||0)+(e.girls||0);
});
%>

<div class="kpi-grid">

<div class="kpi-card">
<h3><%= stats?.students?.total || 0 %></h3>
<p>Total Students</p>
</div>

<div class="kpi-card">
<h3><%= totalQualified %></h3>
<p>Qualification Achievements</p>
</div>

<div class="kpi-card">
<h3><%= totalEmployment %></h3>
<p>Employment Achievements</p>
</div>

<div class="kpi-card">
<h3><%= achievements?.length || 0 %></h3>
<p>Achievement Records</p>
</div>

</div>

<div class="achievement-note">

<strong>Note:</strong>

Achievement counts represent total examination clearances
and employment selections.

Some students have qualified multiple examinations.
Therefore achievement totals may exceed the number of
unique students.

</div>
<div class="summary-row">

  <!-- Qualification -->

  <div class="summary-panel">

    <h2>🎯 Qualification Summary</h2>

    <% stats?.qualified?.forEach(exam => { %>

      <div class="summary-item">

        <div>

          <div class="summary-name">
            <%= exam.name %>
          </div>

          <div class="summary-breakup">

            <span class="boys-tag">
              👨‍🎓 Boys: <%= exam.boys || 0 %>
            </span>
             <span class="divider">|</span>
            <span class="girls-tag">
              👩‍🎓 Girls: <%= exam.girls || 0 %>
            </span>

          </div>

        </div>

        <span class="summary-total">
          <%= (exam.boys || 0) + (exam.girls || 0) %>
        </span>

      </div>

    <% }) %>

  </div>


  <!-- Employment -->

  <div class="summary-panel">

    <h2>💼 Employment Summary</h2>

    <% stats?.employment?.forEach(emp => { %>

      <div class="summary-item">

        <div>

          <div class="summary-name">
            <%= emp.name %>
          </div>

          <div class="summary-breakup">

            <span class="boys-tag">
              👨‍🎓 Boys: <%= emp.boys || 0 %>
            </span>
             <span class="divider">|</span>
            <span class="girls-tag">
              👩‍🎓 Girls: <%= emp.girls || 0 %>
            </span>

          </div>

        </div>

        <span class="summary-total">
          <%= (emp.boys || 0) + (emp.girls || 0) %>
        </span>

      </div>

    <% }) %>

  </div>

</div>

<div class="achievement-content-full">

    <div class="achievement-grid">

      <% if (achievements && achievements.length > 0) { %>

        <% achievements.forEach(item => { %>

          <!-- ✅ WRAPPER (VERY IMPORTANT) -->
 <div class="achievement-card-wrapper">

  <div class="certificate" id="certificate-<%= item._id %>">

    
    <div class="photo-wrapper">
      <img src="/api/upload/<%= item.studentId?.photoId %>" class="profile" />
    </div>

    <h2 class="name">
  <%= item.studentId?.name %>
</h2>

<div class="course-text">
  🎯 <%= item.studentId?.course %> Batch
</div>

    <div class="exam">
      <%= item.examQualified %>
    </div>

  </div>  <!-- ✅ certificate close -->

</div>    <!-- ✅ wrapper close -->

        <% }) %>

      <% } else { %>

        <p>No achievements found</p>

      <% } %>

    </div>

  </div>

</div>

<%- include("../partials/footer") %>