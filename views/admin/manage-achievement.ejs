<%- include("../partials/header") %>

<div class="achievement-container">

  <!-- 🟦 LEFT SIDE -->
  <div class="overview-panel">

    <h3>Overview</h3>

    <div style="margin-bottom:10px;">
      <strong>Total Students:</strong> <%= totalStudents || 0 %>
    </div>

    <div style="margin-bottom:10px;">
      <strong>Boys:</strong> <%= boys || 0 %>
    </div>

    <div style="margin-bottom:10px;">
      <strong>Girls:</strong> <%= girls || 0 %>
    </div>

    <hr>

    <h4>Selections</h4>

    <div>SSC GD: <%= sscCount || 0 %></div>
    <div>CG Police: <%= cgPoliceCount || 0 %></div>
    <div>CTET: <%= ctetCount || 0 %></div>

  </div>
  <!-- 🟩 RIGHT SIDE -->
  <div class="achievement-content">

    <div class="achievement-grid">


      <% if (achievements && achievements.length > 0) { %>

        <% achievements.forEach(item => { %>

<div class="certificate" id="certificate-<%= item._id %>">

  <h3 class="title">Congratulations</h3>

  <!-- IMAGE -->
  <div class="photo-wrapper">
    <img src="/api/upload/<%= item.studentId?.photoId %>" />
  </div>

  <!-- QUOTE -->
  <p class="quote">
    From Classroom Walls <br> to Success Halls
  </p>

  <!-- NAME -->
  <h2 class="name"><%= item.studentId?.name %></h2>

  <!-- EXAM -->
  <div class="exam">
    <%= item.examQualified %>
  </div>

  <!-- BATCH -->
  <p class="batch">CG VYAPAM BATCH</p>

</div>

<button onclick="downloadCertificate('<%= item._id %>')">
  Download
</button>

        <% }) %>

      <% } else { %>

        <p>No achievements found</p>

      <% } %>

    </div>

  </div>

</div>
<%- include("../partials/footer") %>