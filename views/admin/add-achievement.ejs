<h2>Add Achievement</h2>

<form action="/achievement/add" method="POST">

  <!-- 🔹 Filters Row -->
  <div style="display:flex; gap:10px; margin-bottom:15px;">

    <!-- Year -->
    <select id="yearFilter" style="padding:8px;">
      <option value="">Select Year</option>
      <option value="2025-26">2025-26</option>
      <option value="2026-27">2026-27</option>
    </select>

    <!-- Course -->
    <select id="courseFilter" style="padding:8px;">
      <option value="">Select Course</option>
      <option value="CGPSC">CGPSC</option>
      <option value="VYAPAM">VYAPAM</option>
    </select>

  </div>


  <!-- 🔍 Search -->
  <input 
    type="text" 
    id="searchStudent" 
    placeholder="Search student..." 
    style="width:100%; padding:8px; margin-bottom:10px;"
  >


  <!-- 👇 Student Dropdown -->
  <select name="studentId" id="studentDropdown" required style="width:100%; padding:8px;">
    <option value="">-- Select Student --</option>

    <% if (students && students.length > 0) { %>
      <% students.forEach(student => { %>
        <option value="<%= student._id %>">
          <%= student.name %> (<%= student.course %> - <%= student.year %>)
        </option>
      <% }) %>
    <% } else { %>
      <option>No students found</option>
    <% } %>
  </select>


  <br><br>

  <!-- ✍️ Exam -->
  <input 
    type="text" 
    name="examQualified" 
    placeholder="Enter Exam (SSC GD / CTET)" 
    required 
    style="width:100%; padding:8px;"
  >

  <br><br>

  <button type="submit" style="padding:10px 20px;">
    Save Achievement
  </button>

</form>