<h2>Add Achievement</h2>

<form action="/achievement/add" method="POST">

  <label>Select Student</label>
  
  <select name="studentId" required>
    <option value="">-- Select Student --</option>

    <% if (students && students.length > 0) { %>
      <% students.forEach(student => { %>
        <option value="<%= student._id %>">
          <%= student.name %> (<%= student.batch %>)
        </option>
      <% }) %>
    <% } else { %>
      <option>No students found</option>
    <% } %>

  </select>

  <br><br>

  <label>Exam Qualified</label>
  <input type="text" name="examQualified" required>

  <br><br>

  <button type="submit">Save</button>

</form>
<p>Students count: <%= students ? students.length : 0 %></p>