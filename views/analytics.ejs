<%- include("partials/header") %>

<link rel="stylesheet" href="/css/analytics.css">

<div class="analytics-page">

  <div class="analytics-container">

    <!-- =========================================
         PAGE HEADER
    ========================================= -->

    <div class="analytics-header">

      <span class="page-badge">
        Program Analytics
      </span>

      <h1>
        Program Health Dashboard
      </h1>

      <p>
        Real-time overview of attendance,
        student engagement, and program
        performance across all batches.
      </p>

<div class="analytics-filter">

  <label>
    Academic Year
  </label>

  <select
    id="yearFilter"
  >

    <option
      value="all"
      <%= !selectedYear ||
      selectedYear === "all"
      ? "selected" : "" %>
    >
      All Years
    </option>

    <option
      value="2025-26"
      <%= selectedYear === "2025-26"
      ? "selected" : "" %>
    >
      2025-26 (Year 1)
    </option>

    <option
      value="2026-27"
      <%= selectedYear === "2026-27"
      ? "selected" : "" %>
    >
      2026-27 (Year 2)
    </option>

    <option
      value="2027-28"
      <%= selectedYear === "2027-28"
      ? "selected" : "" %>
    >
      2027-28 (Year 3)
    </option>

    <option
      value="2028-29"
      <%= selectedYear === "2028-29"
      ? "selected" : "" %>
    >
      2028-29 (Year 4)
    </option>

  </select>

</div>
</div>

    <!-- =========================================
         KPI CARDS
    ========================================= -->

<div class="analytics-cards">

  <!-- Total Students -->

  <div class="module-card analytics-card">

    <h3>
      🎓
      <%= analyticsData?.totalStudents || 0 %>
    </h3>

    <p>
      Total Students
    </p>

  </div>


  <!-- Active Students -->

  <div class="module-card analytics-card">

    <h3>
      ✅
      <%= analyticsData?.activeStudents || 0 %>
    </h3>

    <p>
      Active Students
    </p>

  </div>


  <!-- Dropout Students -->

  <div class="module-card analytics-card">

    <h3>
      ⚠️
      <%= analyticsData?.dropoutStudents || 0 %>
    </h3>

    <p>
      Dropout Students
    </p>

  </div>


  <!-- Average Attendance -->

  <div class="module-card analytics-card">

    <h3>
      📊 <%= averageAttendance %>%
    </h3>

    <p>
      Average Attendance
    </p>

  </div>


  <!-- Total Tests -->

  <div class="module-card analytics-card">

    <h3>
      📝 <%= totalTests %>
    </h3>

    <p>
      Total Tests
    </p>

  </div>


  <!-- Class Tests -->

  <div class="module-card analytics-card">

    <h3>
      📘 <%= totalClassTests %>
    </h3>

    <p>
      Class Tests
    </p>

  </div>


  <!-- Mock Exams -->

  <div class="module-card analytics-card">

    <h3>
      🎯 <%= totalMockTests %>
    </h3>

    <p>
      Mock Exams
    </p>

  </div>


  <!-- Mains Tests -->

  <div class="module-card analytics-card">

    <h3>
      🏆 <%= totalMainsTests %>
    </h3>

    <p>
      Mains Tests
    </p>

  </div>


  <!-- Students Employed -->

  <div class="module-card analytics-card">

    <h3>
      💼
      <%= analyticsData?.employedStudents || 0 %>
    </h3>

    <p>
      Students Employed
    </p>

  </div>


  <!-- Students Qualified -->

  <div class="module-card analytics-card">

    <h3>
      🥇
      <%= analyticsData?.qualifiedStudents || 0 %>
    </h3>

    <p>
      Students Qualified
    </p>

  </div>


  <!-- Hybrid Learning -->

  <div class="module-card analytics-card">

    <h3>
      💻
      <%= analyticsData?.hybridStudents || 0 %>
    </h3>

    <p>
      Hybrid Learning Students
    </p>

  </div>

</div>


<!-- =========================================
     ATTENDANCE ANALYTICS
========================================= -->

<section class="attendance-section">

  <div class="analytics-header">

    <span class="page-badge">
      Attendance Analytics
    </span>

    <h2>
      Batch-wise Attendance Overview
    </h2>

    <p>
      Monthly attendance comparison across
      CGPSC and VYAPAM coaching batches.
    </p>

  </div>


  <div class="analytics-grid">

    <!-- CGPSC -->

    <div class="module-card analytics-card">

      <h3>
        📘 CGPSC Batch
      </h3>

      <div class="chart-container">

        <canvas id="cgpscChart"></canvas>

      </div>

    </div>


    <!-- VYAPAM -->

    <div class="module-card analytics-card">

      <h3>
        📗 VYAPAM Batch
      </h3>

      <div class="chart-container">

        <canvas id="vyapamChart"></canvas>

      </div>

    </div>

  </div>

</section>


<!-- =========================================
     CHART JS
========================================= -->

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

  window.cgpscAttendance =
  JSON.parse('<%- JSON.stringify(cgpscAttendance || []) %>');

  window.vyapamAttendance =
  JSON.parse('<%- JSON.stringify(vyapamAttendance || []) %>');

</script>

<script src="/js/analytics.js"></script>

<script>

const yearFilter =
document.getElementById("yearFilter");

yearFilter.addEventListener(
  "change",
  function(){

    const selectedYear =
    this.value;

    if(selectedYear === "all"){

      window.location.href =
      "/analytics";

    } else {

      window.location.href =
      "/analytics?year=" +
      selectedYear;
    }
  }
);

</script>

<!-- =========================================
     CLASS TEST ANALYTICS
========================================= -->
<%- include(
  "partials/testTable",
  {
    badge:
    "Class Test Analytics",

    title:
    "Class Test Performance",

    subtitle:
    "Student performance analytics across all class tests.",

    tests:
    classTestAnalytics
  }
) %>


<%- include(
  "partials/testTable",
  {
    badge:
    "Mock Test Analytics",

    title:
    "Mock Exam Performance",

    subtitle:
    "Student performance analytics across all mock exams.",

    tests:
    mockTestAnalytics
  }
) %>


<%- include(
  "partials/testTable",
  {
    badge:
    "Mains Test Analytics",

    title:
    "Mains Test Performance",

    subtitle:
    "Student performance analytics across all mains tests.",

    tests:
    mainsTestAnalytics
  }
) %>

<%- include("partials/footer") %>