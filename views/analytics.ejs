<%- include("partials/header") %>

<link rel="stylesheet" href="/css/analytics.css">

<div class="analytics-page">

  <div class="analytics-container">

    <!-- =========================================
         PAGE HEADER
    ========================================= -->

    <div class="analytics-header">

      <span class="page-badge">
        Program Analytics
      </span>

      <h1>
        Program Health Dashboard
      </h1>

      <p>
        Real-time overview of attendance,
        student engagement, and program
        performance across all batches.
      </p>

<div class="analytics-filter">

  <label>
    Academic Year
  </label>

  <select id="yearFilter">

    <option value="all">
      All Years
    </option>

    <option value="2025-26">
      2025-26 (Year 1)
    </option>

    <option value="2026-27">
      2026-27 (Year 2)
    </option>

    <option value="2027-28">
      2027-28 (Year 3)
    </option>

    <option value="2028-29">
      2028-29 (Year 4)
    </option>

  </select>

</div>

    </div>


    <!-- =========================================
         KPI CARDS
    ========================================= -->

    <div class="analytics-cards">

      <div class="module-card analytics-card">

        <h3>
          🎓 250
        </h3>

        <p>
          Total Students
        </p>

      </div>

      <div class="module-card analytics-card">

        <h3>
          ✅ 214
        </h3>

        <p>
          Active Students
        </p>

      </div>

      <div class="module-card analytics-card">

        <h3>
          ⚠️ 36
        </h3>

        <p>
          Dropout Students
        </p>

      </div>

      <div class="module-card analytics-card">

        <h3>
          📊 78%
        </h3>

        <p>
          Average Attendance
        </p>

      </div>

      <div class="module-card analytics-card">

        <h3>
          📝 42
        </h3>

        <p>
          Tests Conducted
        </p>

      </div>

      <div class="module-card analytics-card">

        <h3>
          💼 12
        </h3>

        <p>
          Students Employed
        </p>

      </div>

    </div>

  </div>

</div>


<!-- =========================================
     ATTENDANCE ANALYTICS
========================================= -->

<section class="attendance-section">

  <div class="analytics-header">

    <span class="page-badge">
      Attendance Analytics
    </span>

    <h2>
      Batch-wise Attendance Overview
    </h2>

    <p>
      Monthly attendance comparison across
      CGPSC and VYAPAM coaching batches.
    </p>

  </div>


  <div class="analytics-grid">

    <!-- CGPSC -->

    <div class="module-card analytics-card">

      <h3>
        📘 CGPSC Batch
      </h3>

      <div class="chart-container">

        <canvas id="cgpscChart"></canvas>

      </div>

    </div>


    <!-- VYAPAM -->

    <div class="module-card analytics-card">

      <h3>
        📗 VYAPAM Batch
      </h3>

      <div class="chart-container">

        <canvas id="vyapamChart"></canvas>

      </div>

    </div>

  </div>

</section>


<!-- =========================================
     CHART JS
========================================= -->

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

  window.cgpscAttendance =
  JSON.parse('<%- JSON.stringify(cgpscAttendance || []) %>');

  window.vyapamAttendance =
  JSON.parse('<%- JSON.stringify(vyapamAttendance || []) %>');

</script>

<script src="/js/analytics.js"></script>

<script>

const yearFilter =
document.getElementById("yearFilter");

yearFilter.addEventListener(
  "change",
  function(){

    const selectedYear =
    this.value;

    if(selectedYear === "all"){

      window.location.href =
      "/analytics";

    } else {

      window.location.href =
      "/analytics?year=" +
      selectedYear;
    }
  }
);

</script>

<!-- =========================================
     CLASS TEST ANALYTICS
========================================= -->

<section class="attendance-section">

  <div class="analytics-header">

    <span class="page-badge">
      Test Analytics
    </span>

    <h2>
      Class Test Performance
    </h2>

    <p>
      Student performance analytics across
      all class tests.
    </p>

  </div>

  <div class="module-card">

    <div class="table-container">

      <table class="analytics-table">

        <thead>

          <tr>

            <th>
              Test Name
            </th>

            <th>
              Appeared
            </th>

            <th>
              Above 50%
            </th>

            <th>
              Topper
            </th>

            <th>
              Top Score
            </th>

            <th>
              Full Marks
            </th>

          </tr>

        </thead>

        <tbody>

          <% classTestAnalytics.forEach(test => { %>

            <tr>

              <td>
                <%= test.testName %>
              </td>

              <td>
                <%= test.appeared %>
              </td>

              <td>
                <%= test.above50 %>
              </td>

              <td>
                <%= test.topper %>
              </td>

              <td>
                <%= test.topScore %>
              </td>

              <td>
                <%= test.fullMarks %>
              </td>

            </tr>

          <% }) %>

        </tbody>

      </table>

    </div>

  </div>

</section>

<%- include("partials/footer") %>