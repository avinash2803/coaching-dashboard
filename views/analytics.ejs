<%- include("partials/header") %>

<link rel="stylesheet" href="/css/index.css">
<link rel="stylesheet" href="/css/analytics.css">

<!-- =========================================
     ANALYTICS HERO
========================================= -->

<section class="section analytics-hero">

  <div class="section-line-header">

    <div class="section-badge">
      Program Analytics
    </div>

  </div>

  <div class="analytics-hero-content">

    <h1>
      Program Health Dashboard
    </h1>

    <p>
      Real-time overview of attendance, student engagement,
      academic progress, and program performance across
      BALCO Connect Coaching Program batches.
    </p>

    <div class="analytics-filter">

      <label>
        Academic Year
      </label>

      <select>

        <option>
          All Years
        </option>

        <option>
          2025-26
        </option>

        <option>
          2026-27
        </option>

      </select>

    </div>

  </div>

</section>

<!-- =========================================
     KPI CARDS
========================================= -->

<section class="section">

  <div class="stats">

    <div class="stat-card">

      <h3>
        🎓 250
      </h3>

      <p>
        Total Students Enrolled
      </p>

    </div>

    <div class="stat-card">

      <h3>
        ✅ 214
      </h3>

      <p>
        Active Students
      </p>

    </div>

    <div class="stat-card">

      <h3>
        ⚠️ 36
      </h3>

      <p>
        Dropout Students
      </p>

    </div>

    <div class="stat-card">

      <h3>
        📊 78%
      </h3>

      <p>
        Average Attendance
      </p>

    </div>

    <div class="stat-card">

      <h3>
        📝 42
      </h3>

      <p>
        Tests Conducted
      </p>

    </div>

    <div class="stat-card">

      <h3>
        💼 12
      </h3>

      <p>
        Students Employed
      </p>

    </div>

  </div>

</section>

