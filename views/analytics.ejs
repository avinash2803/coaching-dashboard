<%- include("partials/header") %>

<link rel="stylesheet" href="/css/analytics.css">

<div class="analytics-page">

  <div class="analytics-container">

    <!-- =========================================
         PAGE HEADER
    ========================================= -->

    <div class="analytics-header">

      <span class="page-badge">
        Program Analytics
      </span>

      <h1>
        Program Health Dashboard
      </h1>

      <p>
        Real-time overview of attendance,
        student engagement, and program
        performance across all batches.
      </p>

<div class="analytics-filter">

  <label>
    Academic Year
  </label>

  <select
    id="yearFilter"
  >

    <option
      value="all"
      <%= !selectedYear ||
      selectedYear === "all"
      ? "selected" : "" %>
    >
      All Years
    </option>

    <option
      value="2025-26"
      <%= selectedYear === "2025-26"
      ? "selected" : "" %>
    >
      2025-26 (Year 1)
    </option>

    <option
      value="2026-27"
      <%= selectedYear === "2026-27"
      ? "selected" : "" %>
    >
      2026-27 (Year 2)
    </option>

    <option
      value="2027-28"
      <%= selectedYear === "2027-28"
      ? "selected" : "" %>
    >
      2027-28 (Year 3)
    </option>

    <option
      value="2028-29"
      <%= selectedYear === "2028-29"
      ? "selected" : "" %>
    >
      2028-29 (Year 4)
    </option>

  </select>

</div>
</div>

    <!-- =========================================
         KPI CARDS
    ========================================= -->

    <h3 class="section-title">
  📊 Student Impact Metrics
</h3>

<div class="analytics-cards">

  <!-- Total Students -->

  <div class="module-card analytics-card">

    <h3>
      🎓
      <%= analyticsData?.totalStudents || 0 %>
    </h3>

    <p>
      Total Students
    </p>

  </div>


  <!-- Active Students -->

  <div class="module-card analytics-card">

    <h3>
      ✅
      <%= analyticsData?.activeStudents || 0 %>
    </h3>

    <p>
      Active Students
    </p>

  </div>


  <!-- Dropout Students -->

  <div class="module-card analytics-card">

    <h3>
      ⚠️
      <%= analyticsData?.dropoutStudents || 0 %>
    </h3>

    <p>
      Dropout Students
    </p>

  </div>


  <!-- Average Attendance -->

<div
  class="module-card analytics-card clickable-card"
  onclick="scrollToAttendance()"
>

  <h3>
    📊 <%= averageAttendance %>%
  </h3>

  <p>
    Average Attendance
  </p>

</div>


  <!-- Students Employed -->

  <div class="module-card analytics-card">

    <h3>
      💼
      <%= analyticsData?.employedStudents || 0 %>
    </h3>

    <p>
      Students Employed
    </p>

  </div>


  <!-- Students Qualified -->

  <div class="module-card analytics-card">

    <h3>
      🥇
      <%= analyticsData?.qualifiedStudents || 0 %>
    </h3>

    <p>
      Students Qualified
    </p>

  </div>


  <!-- Hybrid Learning -->

  <div class="module-card analytics-card">

    <h3>
      💻
      <%= analyticsData?.hybridStudents || 0 %>
    </h3>

    <p>
      Hybrid Learning Students
    </p>

  </div>

</div> <!-- analytics-cards -->

<h3 class="section-title">
  📝 Assessment & Exam Metrics
</h3>

<div class="analytics-cards">

  <!-- Total Tests -->

  <div
    class="module-card analytics-card clickable-card"
    onclick="showBatchOptions()"
  >

    <h3>
      📝 <%= totalTests %>
    </h3>

    <p>
      Total Tests
    </p>

  </div>

  <!-- Class Tests -->

  <div class="module-card analytics-card">

    <h3>
      📘 <%= totalClassTests %>
    </h3>

    <p>
      Class Tests
    </p>

  </div>

  <!-- Mock Exams -->

  <div class="module-card analytics-card">

    <h3>
      🎯 <%= totalMockTests %>
    </h3>

    <p>
      Mock Exams
    </p>

  </div>

  <!-- Mains Tests -->

  <div class="module-card analytics-card">

    <h3>
      🏆 <%= totalMainsTests %>
    </h3>

    <p>
      Mains Tests
    </p>

  </div>

</div>

<!-- Batch Selection -->

<div
  id="batchOptions"
  class="analytics-cards"
  style="display:none;"
>

  <div
    class="module-card analytics-card clickable-card"
    onclick="showCGPSC()"
  >

    <h3>
      📘
      <%= cgpscClassTests.length +
          cgpscMockTests.length +
          cgpscMainsTests.length %>
    </h3>

    <p>
      CGPSC Total Tests
    </p>

  </div>

  <div
    class="module-card analytics-card clickable-card"
    onclick="showVYAPAM()"
  >

    <h3>
      📗
      <%= vyapamClassTests.length +
          vyapamMockTests.length %>
    </h3>

    <p>
      VYAPAM Total Tests
    </p>

  </div>

</div>

<!-- CGPSC Categories -->

<div
  id="cgpscOptions"
  class="analytics-cards"
  style="display:none;"
>

  <div
    class="module-card analytics-card clickable-card"
    onclick="showTable('cgpscClass')"
  >

    <h3>
      📘 <%= cgpscClassTests.length %>
    </h3>

    <p>
      Class Tests
    </p>

  </div>

  <div
    class="module-card analytics-card clickable-card"
    onclick="showTable('cgpscMock')"
  >

    <h3>
      🎯 <%= cgpscMockTests.length %>
    </h3>

    <p>
      Mock Exams
    </p>

  </div>

  <div
    class="module-card analytics-card clickable-card"
    onclick="showTable('cgpscMains')"
  >

    <h3>
      🏆 <%= cgpscMainsTests.length %>
    </h3>

    <p>
      Mains Tests
    </p>

  </div>

</div>

<!-- VYAPAM Categories -->

<div
  id="vyapamOptions"
  class="analytics-cards"
  style="display:none;"
>

  <div
    class="module-card analytics-card clickable-card"
    onclick="showTable('vyapamClass')"
  >

    <h3>
      📘 <%= vyapamClassTests.length %>
    </h3>

    <p>
      Class Tests
    </p>

  </div>

  <div
    class="module-card analytics-card clickable-card"
    onclick="showTable('vyapamMock')"
  >

    <h3>
      🎯 <%= vyapamMockTests.length %>
    </h3>

    <p>
      Mock Exams
    </p>

  </div>

</div>

<h3 class="section-title">
  🎯 Program Delivery Metrics
</h3>

<div class="analytics-cards">

  <div class="module-card analytics-card">

    <h3>
      📅 <%= totalDays || 0 %>
    </h3>

    <p>
      Total Program Days
    </p>

  </div>

  <div class="module-card analytics-card">

    <h3>
      🏫 <%= totalSessions || 0 %>+
    </h3>

    <p>
      Total Sessions Conducted
    </p>

  </div>

  <div class="module-card analytics-card">

    <h3>
    ⏱ <%= totalHours || 0 %>+
    </h3>

    <p>
      Total Learning Hours
    </p>

  </div>

</div>


<!-- =========================================
     ATTENDANCE ANALYTICS
========================================= -->
<section class="attendance-section">

  <div class="analytics-container">

    <div class="analytics-header">

      <span class="page-badge">
        Attendance Analytics
      </span>

      <h2>
        Batch-wise Attendance Overview
      </h2>

      <p>
        Monthly attendance comparison across
        CGPSC and VYAPAM coaching batches.
      </p>

    </div>

    <div class="analytics-grid">

      <!-- CGPSC -->

      <div class="module-card analytics-card">

        <h3>
          📘 CGPSC Batch
        </h3>

        <div class="chart-container">

          <canvas id="cgpscChart"></canvas>

        </div>

      </div>


      <!-- VYAPAM -->

      <div class="module-card analytics-card">

        <h3>
          📗 VYAPAM Batch
        </h3>

        <div class="chart-container">

          <canvas id="vyapamChart"></canvas>

        </div>

      </div>

    </div>

  </div>

</section>

<!-- =========================================
     CHART JS
========================================= -->

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

  window.cgpscAttendance =
  JSON.parse('<%- JSON.stringify(cgpscAttendance || []) %>');

  window.vyapamAttendance =
  JSON.parse('<%- JSON.stringify(vyapamAttendance || []) %>');

</script>

<script src="/js/analytics.js"></script>

<script>

const yearFilter =
document.getElementById("yearFilter");

yearFilter.addEventListener(
  "change",
  function(){

    const selectedYear =
    this.value;

    if(selectedYear === "all"){

      window.location.href =
      "/analytics";

    } else {

      window.location.href =
      "/analytics?year=" +
      selectedYear;
    }
  }
);

</script>

<!-- =========================================
     CLASS TEST ANALYTICS
========================================= -->
<div
  id="cgpscClass"
  style="display:none;"
>

<%- include(
  "partials/testTable",
  {
    badge:
    "CGPSC Class Tests",

    title:
    "CGPSC Class Test Performance",

    subtitle:
    "CGPSC student performance.",

    tests:
    cgpscClassTests
  }
) %>

</div>


<div
  id="cgpscMock"
  style="display:none;"
>

<%- include(
  "partials/testTable",
  {
    badge:
    "CGPSC Mock Tests",

    title:
    "CGPSC Mock Exam Performance",

    subtitle:
    "CGPSC mock exam analytics.",

    tests:
    cgpscMockTests
  }
) %>

</div>


<div
  id="cgpscMains"
  style="display:none;"
>

<%- include(
  "partials/testTable",
  {
    badge:
    "CGPSC Mains Tests",

    title:
    "CGPSC Mains Performance",

    subtitle:
    "CGPSC mains analytics.",

    tests:
    cgpscMainsTests
  }
) %>

</div>

<div
  id="vyapamClass"
  style="display:none;"
>

<%- include(
  "partials/testTable",
  {
    badge:
    "VYAPAM Class Tests",

    title:
    "VYAPAM Class Test Performance",

    subtitle:
    "VYAPAM class test analytics.",

    tests:
    vyapamClassTests
  }
) %>

</div>

<div
  id="vyapamMock"
  style="display:none;"
>

<%- include(
  "partials/testTable",
  {
    badge:
    "VYAPAM Mock Tests",

    title:
    "VYAPAM Mock Exam Performance",

    subtitle:
    "VYAPAM mock analytics.",

    tests:
    vyapamMockTests
  }
) %>

</div>

<script>

function showBatchOptions(){

  const batchOptions =
  document.getElementById(
    "batchOptions"
  );

  if(
    batchOptions.style.display ===
    "grid"
  ){

    batchOptions.style.display =
    "none";

    document.getElementById(
      "cgpscOptions"
    ).style.display = "none";

    document.getElementById(
      "vyapamOptions"
    ).style.display = "none";

  } else {

    batchOptions.style.display =
    "grid";
  }
}
function showCGPSC(){

  document.getElementById(
    "cgpscOptions"
  ).style.display = "grid";

  document.getElementById(
    "vyapamOptions"
  ).style.display = "none";

  document.getElementById(
    "cgpscOptions"
  ).scrollIntoView({

    behavior: "smooth",

    block: "start"
  });
}

function showVYAPAM(){

  document.getElementById(
    "vyapamOptions"
  ).style.display = "grid";

  document.getElementById(
    "cgpscOptions"
  ).style.display = "none";

  document.getElementById(
    "vyapamOptions"
  ).scrollIntoView({

    behavior: "smooth",

    block: "start"
  });
}

function scrollToAttendance(){

  document.querySelector(
    ".attendance-section"
  ).scrollIntoView({

    behavior: "smooth",

    block: "start"
  });
}

function showTable(id){

  const sections = [

    "cgpscClass",
    "cgpscMock",
    "cgpscMains",
    "vyapamClass",
    "vyapamMock"
  ];

  sections.forEach(section => {

    const element =
    document.getElementById(section);

    if(element){

      element.style.display = "none";
    }
  });

const activeSection =
document.getElementById(id);

activeSection.style.display =
"block";

activeSection.scrollIntoView({

  behavior: "smooth",

  block: "start"
});
}

</script>

<%- include("partials/footer") %>