<%- include("partials/header") %>

<link rel="stylesheet" href="/css/index.css">
<link rel="stylesheet" href="/css/analytics.css">

<!-- =========================================
     HERO
========================================= -->

<section class="section analytics-hero">

  <div class="section-line-header">

    <div class="section-badge">
      Program Analytics
    </div>

  </div>

  <div class="analytics-hero-content">

    <h1>
      Program Health Dashboard
    </h1>

    <p>
      Real-time overview of attendance, student engagement,
      academic performance, and test analytics across
      BALCO Connect Coaching Program.
    </p>

    <div class="analytics-filter">

      <label>
        Academic Year
      </label>

      <select>

        <option>
          All Years
        </option>

        <option>
          2025-26
        </option>

        <option>
          2026-27
        </option>

      </select>

    </div>

  </div>

</section>

<!-- =========================================
     KPI OVERVIEW
========================================= -->

<section class="section">

  <div class="stats">

    <div class="stat-card">

      <h3>
        🎓 250
      </h3>

      <p>
        Total Students Enrolled
      </p>

    </div>

    <div class="stat-card">

      <h3>
        ✅ 214
      </h3>

      <p>
        Active Students
      </p>

    </div>

    <div class="stat-card">

      <h3>
        ⚠️ 36
      </h3>

      <p>
        Dropout Students
      </p>

    </div>

    <div class="stat-card">

      <h3>
        📊 78%
      </h3>

      <p>
        Average Attendance
      </p>

    </div>

  </div>

</section>

<!-- =========================================
     ATTENDANCE ANALYTICS
========================================= -->

<section class="section">

  <div class="section-line-header">

    <div class="section-badge">
      Attendance Analytics
    </div>

  </div>

  <p class="section-subtitle">

    Batch-wise monthly attendance overview for
    CGPSC and VYAPAM batches.

  </p>

  <div class="analytics-grid">

    <!-- CGPSC -->

    <div class="program-card">

      <h3>
        📘 CGPSC Batch
      </h3>

      <div class="chart-container">

        <canvas id="cgpscChart"></canvas>

      </div>

    </div>

    <!-- VYAPAM -->

    <div class="program-card">

      <h3>
        📗 VYAPAM Batch
      </h3>

      <div class="chart-container">

        <canvas id="vyapamChart"></canvas>

      </div>

    </div>

  </div>

</section>

<!-- =========================================
     TEST ANALYTICS
========================================= -->

<section class="section">

  <div class="section-line-header">

    <div class="section-badge">
      Test Analytics
    </div>

  </div>

  <p class="section-subtitle">

    Performance insights generated automatically
    from uploaded test data.

  </p>

  <div class="analytics-grid">

    <% testAnalytics.forEach(test => { %>

      <div class="program-card">

        <h3>
          📝 <%= test.testName %>
        </h3>

        <p>
          <strong>Subject:</strong>
          <%= test.subject %>
        </p>

        <p>
          <strong>Full Marks:</strong>
          <%= test.fullMarks %>
        </p>

        <p>
          <strong>Candidates:</strong>
          <%= test.candidatesAppeared %>
        </p>

        <p>
          <strong>Absent:</strong>
          <%= test.absentStudents %>
        </p>

        <p>
          <strong>Average Score:</strong>
          <%= test.averageScore %>
        </p>

        <p>
          <strong>Average %:</strong>
          <%= test.averagePercentage %>%
        </p>

        <p>
          <strong>Above 50%:</strong>
          <%= test.above50 %>
        </p>

        <p>
          <strong>Topper:</strong>
          <%= test.topperName %>
        </p>

        <p>
          <strong>Top Score:</strong>
          <%= test.topScore %>
        </p>

      </div>

    <% }) %>

  </div>

</section>

<%- include("partials/footer") %>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="/js/analytics.js"></script>