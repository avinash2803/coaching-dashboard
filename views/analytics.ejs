<%- include("partials/header") %>

<link rel="stylesheet" href="/css/analytics.css">

<div class="analytics-page">

  <div class="analytics-container">

    <div class="analytics-header">

      <span class="analytics-badge">
        Program Analytics
      </span>

      <h1>
        Program Health Dashboard
      </h1>

      <p>
        Real-time overview of attendance,
        student engagement, and program
        performance across all batches.
      </p>

      <div class="analytics-filter">

        <label>
          Academic Year
        </label>

        <select>

          <option>
            All Years
          </option>

          <option>
            2025-26
          </option>

          <option>
            2026-27
          </option>

        </select>

      </div>

    </div>

    <div class="analytics-cards">

      <div class="analytics-card">

        <h3>🎓 250</h3>

        <p>Total Students</p>

      </div>

      <div class="analytics-card">

        <h3>✅ 214</h3>

        <p>Active Students</p>

      </div>

      <div class="analytics-card">

        <h3>⚠️ 36</h3>

        <p>Dropout Students</p>

      </div>

      <div class="analytics-card">

        <h3>📊 78%</h3>

        <p>Average Attendance</p>

      </div>

      <div class="analytics-card">

        <h3>📝 42</h3>

        <p>Tests Conducted</p>

      </div>

      <div class="analytics-card">

        <h3>💼 12</h3>

        <p>Students Employed</p>

      </div>

    </div>

  </div>

</div>

<%- include("partials/footer") %>